# Public Supabase config. These values are safe to expose only when they are
# Supabase anon/publishable keys. Never put service role keys in VITE_* values.
SUPABASE_PROJECT_ID=""
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Server-only secrets. Keep these only in local/server environment variables.
SUPABASE_SERVICE_ROLE_KEY=""
LOVABLE_API_KEY=""

# App/runtime config
NODE_ENV="development"
APP_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
